# Server environment variables
# Copy this file to ".env" in the server/ directory and fill in real values.

# Port the Express server listens on (defaults to 3000 if unset)
PORT=5000

# MongoDB connection string (the app appends "/car-rental" as the DB name)
MONGODB_URI=your_mongodb_connection_string

# Secret used to sign JWT auth tokens
JWT_SECRET=your_jwt_secret

# ImageKit.io credentials (https://imagekit.io/dashboard/developer/api-keys)
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=your_imagekit_url_endpoint
